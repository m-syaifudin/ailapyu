{$DOMAIN_NAME} {
    # 1. Route API requests
    handle /api/* {
        # Strip '/api' from the request path before forwarding to the backend
        uri strip_prefix /api
        reverse_proxy api:8000
    }

    # 2. Simple fix for your chat route
    rewrite /chat /index.html

    # 3. Send everything else to the frontend normally
    handle {
        reverse_proxy frontend:80
    }
}