{$DOMAIN_NAME} {
    # 1. Route ONLY specific API requests to the backend
    # Example: yourdomain/api/chat -> api:8000/chat
    handle /api/* {        
        uri strip_prefix /api
        reverse_proxy api:8000
    }

    # 2. Send EVERYTHING ELSE to the Flutter frontend
    # Example: yourdomain/ or /chat -> frontend:80
    handle {
        reverse_proxy frontend:80
    }
}
