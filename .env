# ============================================================
# AiLapYu — Runtime Configuration
# ============================================================

# ----- Ollama -----
OLLAMA_PORT=11434
OLLAMA_MEMORY_LIMIT=3g
OLLAMA_KEEP_ALIVE=5m

# ----- Model -----
# Best picks for a 4 GB VPS:
#   llama3.2:1b   ~1.3 GB  balanced default
#   qwen2.5:0.5b  ~0.4 GB  ultra-light
#   phi3:mini     ~2.3 GB  smarter but heavier
DEFAULT_MODEL=llama3.2:1b
AUTO_PULL_MODEL=true

# Internal URL used by the api service to reach ollama
# Keep this value when running via docker compose
OLLAMA_BASE_URL=http://ollama:11434

# ----- API -----
API_PORT=8000

# Optional API key — leave blank to disable auth
# Example: openssl rand -hex 16
API_KEY=

# ----- Logging -----
# Options: debug | info | warning | error
LOG_LEVEL=info